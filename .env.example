BOT_TOKEN=123456:ABC-your-telegram-bot-token
ADMIN_IDS=123456789,987654321

# PostgreSQL ulanish manzili (masalan Neon: https://neon.tech)
# Muhim: Neon'da "-pooler" qo'shilgan (PgBouncer) manzil emas, TO'G'RIDAN-TO'G'RI
# ulanish manzilini ishlating (asyncpg o'zi pool qiladi).
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Mini App sozlamalari
WEBAPP_URL=
DEV_MODE=false

# Webhook rejimi (productionda, masalan Render'da, to'ldiriladi)
# Bo'sh qolsa, bot lokal uzun-so'rov (long polling) rejimida ishlaydi.
WEBHOOK_URL=
WEBHOOK_SECRET=hrbotwebhook
